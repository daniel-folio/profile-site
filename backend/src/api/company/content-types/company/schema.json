{
  "kind": "collectionType",
  "collectionName": "experiences",
  "info": {
    "singularName": "company",
    "pluralName": "companies",
    "displayName": "20. Company(경력)",
    "description": "회사/경력 정보"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "company": {
      "type": "string",
      "required": true,
      "displayName": "Company(회사명)"
    },
    "position": {
      "type": "string",
      "required": true,
      "displayName": "Position(직책)"
    },
    "employmentType": {
      "type": "enumeration",
      "default": "Full-time",
      "enum": [
        "Full-time",
        "Part-time",
        "Contract",
        "Freelance"
      ],
      "displayName": "Employment Type(고용형태)"
    },
    "location": {
      "type": "string",
      "displayName": "Location(지역)"
    },
    "startDate": {
      "type": "string",
      "required": true,
      "displayName": "Start Date(입사년월)"
    },
    "endDate": {
      "type": "string",
      "displayName": "End Date(퇴사년월)"
    },
    "companyLogo": {
      "type": "media",
      "multiple": false,
      "displayName": "Company Logo(회사로고)"
    },
    "isCurrent": {
      "type": "boolean",
      "default": false,
      "displayName": "Is Current(재직중)"
    },
    "order": {
      "type": "integer",
      "displayName": "Order(정렬순서)"
    },
    "description": {
      "type": "richtext",
      "displayName": "Description(설명)"
    },
    "isBasicShow": {
      "type": "boolean",
      "default": true,
      "description": "📌 이력서 화면에서 기본으로 노출할 항목이면 체크 (해제 시 '더보기' 안에 숨겨짐)"
    },
    "achievements": {
      "type": "text",
      "displayName": "Achievements(성과)"
    }
  }
}
