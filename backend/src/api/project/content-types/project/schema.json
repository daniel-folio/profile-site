{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "22. Project(프로젝트)",
    "description": "프로젝트 정보"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "projectType": {
      "type": "enumeration",
      "required": true,
      "default": "Web",
      "enum": [
        "Web",
        "Ai",
        "Mobile",
        "Desktop",
        "API",
        "Library",
        "Other"
      ]
    },
    "projectStatus": {
      "type": "enumeration",
      "required": true,
      "default": "Completed",
      "enum": [
        "Completed",
        "In Progress",
        "Planned",
        "On Hold"
      ]
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "thumbnailImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "startDate": {
      "type": "string"
    },
    "endDate": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "visible": {
      "type": "boolean",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "featuredOrder": {
      "type": "integer",
      "default": 0
    },
    "liveUrl": {
      "type": "string"
    },
    "githubUrl": {
      "type": "string"
    },
    "shortDescription": {
      "type": "richtext"
    },
    "fullDescription": {
      "type": "richtext"
    },
    "company": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::company.company",
      "displayName": "Company(회사)"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "displayName": "Technologies(기술스택)"
    }
  }
}
