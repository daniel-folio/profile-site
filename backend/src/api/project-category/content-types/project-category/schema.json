      "required": true,
      "unique": true,
      "displayName": "Name(유형명)"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "displayName": "Slug(슬러그)"
    },
    "projects": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "category"
    }
  }
}
