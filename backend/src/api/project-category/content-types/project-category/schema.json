{
  "kind": "collectionType",
  "collectionName": "project_categories",
  "info": {
    "singularName": "project-category",
    "pluralName": "project-categories",
    "displayName": "23. Project Category(프로젝트 유형)",
    "description": "프로젝트 유형 관리"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
